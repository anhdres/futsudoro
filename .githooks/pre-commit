#!/bin/bash
# Pre-commit hook for futsudoro.
# 1. Bump build version (auto-update BUILD SHA + date in data.js)
# 2. Run repo hygiene check (block if violated)

cd "$(dirname "$0")/.."

# Bump version first (this may modify web/src/data.js and stage it)
./scripts/bump-version.sh

# Then run hygiene check
exec ./scripts/check-hygiene.sh
